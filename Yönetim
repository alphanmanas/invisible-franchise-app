    ["Aylık Personel Gideri & Sair Giderler ($)", monthly_personnel_other, "Editable"],
    ["Franchise Bedeli (USD)", franchise_fee_usd, "Editable"],
], columns=["Alan", "Değer", "Tip"])

calculated_df = pd.DataFrame([
    ["Aylık Brüt Kazanç", gross_sales_after_discount, "((Satış Fiyatı x Adet Toplamı) x (1 - Bayi İndirimi))", "Calculated"],
    ["Aylık Kira Gideri", monthly_rent_expense, "Dükkanın Büyüklüğü x Kira (m2)", "Calculated"],
    ["Aylık Net Gelir", monthly_net_income, "Aylık Brüt Kazanç - Aylık Kira Gideri - Aylık Personel Gideri & Sair Giderler", "Calculated"],
    ["Dekorasyon Bedeli", decoration_total, "Dükkanın Büyüklüğü x Dekorasyon Maliyeti (m2)", "Calculated"],
