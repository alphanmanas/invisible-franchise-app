# =========================================================
# HELPERS
# =========================================================
def usd(value: float) -> str:
    return f"${value:,.2f}"

def num(value: float) -> str:
    return f"{value:,.2f}"

def safe_months(value):
    if value is None:
        return "N/A"
    return f"{value:,.1f}"

# =========================================================
# HEADER
# =========================================================
st.markdown('<div class="top-title">Invisible Hair Franchising Modeli (Yönetim İçin)</div>', unsafe_allow_html=True)
