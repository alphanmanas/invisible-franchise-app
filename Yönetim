    ["Tepelik İthalat Maliyeti - Small ($)", import_cost_top_small, "Editable"],
    ["Tepelik İthalat Maliyeti - Medium ($)", import_cost_top_medium, "Editable"],
    ["Premium Peruk Satış Fiyatı - Kısa ($)", sale_price_short, "Editable"],
    ["Premium Peruk Satış Fiyatı - Medium ($)", sale_price_medium, "Editable"],
    ["Premium Peruk Satış Fiyatı - Uzun ($)", sale_price_long, "Editable"],
