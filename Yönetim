    import_cost_top_small = st.number_input("Tepelik İthalat Maliyeti - Small ($)", min_value=0.0, value=600.0, step=10.0)
    import_cost_top_medium = st.number_input("Tepelik İthalat Maliyeti - Medium ($)", min_value=0.0, value=750.0, step=10.0)

with st.sidebar.expander("Satış Fiyatları", expanded=True):
    sale_price_short = st.number_input("Premium Peruk Satış Fiyatı - Kısa ($)", min_value=0.0, value=3000.0, step=10.0)
    sale_price_medium = st.number_input("Premium Peruk Satış Fiyatı - Medium ($)", min_value=0.0, value=3500.0, step=10.0)
    sale_price_long = st.number_input("Premium Peruk Satış Fiyatı - Uzun ($)", min_value=0.0, value=4000.0, step=10.0)
    sale_price_top_small = st.number_input("Tepelik Satış Fiyatı - Small ($)", min_value=0.0, value=1800.0, step=10.0)
    sale_price_top_medium = st.number_input("Tepelik Satış Fiyatı - Medium ($)", min_value=0.0, value=2200.0, step=10.0)

with st.sidebar.expander("Aylık Satış Adetleri", expanded=True):
    qty_short = st.number_input("Premium Peruk Satış Adedi - Kısa", min_value=0.0, value=6.0, step=1.0)
    qty_medium = st.number_input("Premium Peruk Satış Adedi - Medium", min_value=0.0, value=5.0, step=1.0)
    qty_long = st.number_input("Premium Peruk Satış Adedi - Uzun", min_value=0.0, value=4.0, step=1.0)
    qty_top_small = st.number_input("Tepelik Satış Adedi - Small", min_value=0.0, value=4.0, step=1.0)
    qty_top_medium = st.number_input("Tepelik Satış Adedi - Medium", min_value=0.0, value=3.0, step=1.0)

with st.sidebar.expander("Diğer Yönetim Girdileri", expanded=True):
    dealer_discount = st.number_input("Bayi İndirimi (%)", min_value=0.0, max_value=100.0, value=30.0, step=1.0) / 100
    monthly_personnel_other = st.number_input("Aylık Personel Gideri & Sair Giderler ($)", min_value=0.0, value=7000.0, step=100.0)
    franchise_fee_usd = st.number_input("Franchise Bedeli (USD)", min_value=0.0, value=40000.0, step=1000.0)

# =========================================================
# CALCULATIONS
# =========================================================
gross_sales_before_discount = (
    (sale_price_short * qty_short) +
    (sale_price_medium * qty_medium) +
    (sale_price_long * qty_long) +
    (sale_price_top_small * qty_top_small) +
    (sale_price_top_medium * qty_top_medium)
)

gross_sales_after_discount = gross_sales_before_discount * (1 - dealer_discount)
monthly_rent_expense = store_size_m2 * rent_per_m2
monthly_net_income = gross_sales_after_discount - monthly_rent_expense - monthly_personnel_other
decoration_total = store_size_m2 * decoration_cost_per_m2
initial_investment_total = franchise_fee_usd + decoration_total

payback_months = None
if monthly_net_income > 0:
    payback_months = initial_investment_total / monthly_net_income

# =========================================================
# STATUS
# =========================================================
if monthly_net_income > 0:
    status_text = "Pozitif"
    status_class = "status-good"
elif monthly_net_income == 0:
    status_text = "Başa Baş"
    status_class = "status-neutral"
else:
    status_text = "Negatif"
    status_class = "status-bad"

