    st.dataframe(products_display, use_container_width=True, hide_index=True)

    total_product_gross_profit = products_df["Aylık Brüt Kâr ($)"].sum()
    st.markdown(
        f'<div class="small-note">Ürün bazlı toplam aylık brüt kâr: <b>{usd(total_product_gross_profit)}</b></div>',
        unsafe_allow_html=True
    )

