        editable_display = editable_df.copy()
        editable_display["Değer"] = editable_display.apply(
            lambda x: f"%{x['Değer']:,.1f}" if x["Alan"] == "Bayi İndirimi (%)"
            else f"{x['Değer']:,.0f}" if "Adedi" in x["Alan"] or "(m2)" in x["Alan"]
